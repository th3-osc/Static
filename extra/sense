local viewportSize = camera.ViewportSize
local container = Instance.new("Folder", gethui and gethui() or game:GetService("CoreGui"))
local floor = math.floor
local round = math.round
local sin = math.sin
local cos = math.cos
local clear = table.clear
local find = table.find
local fromMatrix = CFrame.fromMatrix
local wtvp = camera.WorldToViewportPoint
local isA = workspace.IsA
local getPivot = workspace.GetPivot
local findFirstChild = workspace.FindFirstChild
local getChildren = workspace.GetChildren
local lerpColor = Color3.new().Lerp
local min3 = Vector3.zero.Min
local max3 = Vector3.zero.Max
local HEALTH_BAR_OFFSET = Vector2.new(5, 0)
local HEALTH_TEXT_OFFSET = Vector2.new(3, 0)
local HEALTH_BAR_OUTLINE_OFFSET = Vector2.new(0, 1)
local NAME_OFFSET = Vector2.new(0, 2)
local DISTANCE_OFFSET = Vector2.new(0, 2)
local WHITE = Color3.new(1, 1, 1)
local VERTICES = {
	Vector3.new(-1, -1, -1),
	Vector3.new(-1, 1, -1),
	Vector3.new(-1, 1, 1),
	Vector3.new(-1, -1, 1),
	Vector3.new(1, -1, -1),
	Vector3.new(1, 1, -1),
	Vector3.new(1, 1, 1),
	Vector3.new(1, -1, 1)
}

local function isBodyPart(name)
	return name == "Head" or name:find("Torso") or name:find("Leg") or name:find("Arm")
end

local function getBoundingBox(parts)
	local min, max
	for i = 1, #parts do
		local part = parts[i]
		local cframe, size = part.CFrame, part.Size
		min = min3(min or cframe.Position, (cframe - size * 0.5).Position)
		max = max3(max or cframe.Position, (cframe + size * 0.5).Position)
	end
	local center = (min + max) * 0.5
	return CFrame.new(center, Vector3.new(center.X, center.Y, max.Z)), max - min
end

local function worldToScreen(world)
	local screen, visible = wtvp(camera, world)
	return Vector2.new(screen.X, screen.Y), visible, screen.Z
end

local function calculateCorners(cframe, size, data)
	local corners = data and data.corners or {}
	local minX, minY = viewportSize.X, viewportSize.Y
	local maxX, maxY = 0, 0
	for i = 1, 8 do
		local point = worldToScreen((cframe + size * 0.5 * VERTICES[i]).Position)
		corners[i] = point
		local x, y = point.X, point.Y
		if x < minX then
			minX = x
		end
		if y < minY then
			minY = y
		end
		if x > maxX then
			maxX = x
		end
		if y > maxY then
			maxY = y
		end
	end
	data = data or { corners = corners }
	data.topLeft = Vector2.new(floor(minX), floor(minY))
	data.topRight = Vector2.new(floor(maxX), floor(minY))
	data.bottomLeft = Vector2.new(floor(minX), floor(maxY))
	data.bottomRight = Vector2.new(floor(maxX), floor(maxY))
	return data
end

local function rotateVector(vector, radians)
	local x, y = vector.X, vector.Y
	local c, s = cos(radians), sin(radians)
	return Vector2.new(x * c - y * s, x * s + y * c)
end

local function parseColor(self, color, isOutline)
	if color == "Team Color" or self.interface.sharedSettings.useTeamColor and not isOutline then
		if not self._teamColorCached then
			self._teamColor = Utils.Player.GetTeamColor(self.player) or WHITE
			self._teamColorCached = true
		end
		return self._teamColor
	end
	return color
end

local function getOptions(interface, player)
	return interface.teamSettings[Utils.Player.IsFriendly(player) and "friendly" or "enemy"]
end

local function isEnabled(interface, options, character, userId)
	return options.enabled and character and not (#interface.whitelist > 0 and not find(interface.whitelist, userId))
end

local function applyTextStyle(draw, shared, color, transparency, outline, outlineColor)
	draw.Size = shared.textSize
	draw.Font = shared.textFont
	draw.Color = color
	draw.Transparency = transparency
	draw.Outline = outline
	draw.OutlineColor = outlineColor
end

local function createLineSet(self)
	return {
		self:_create("Line", { Thickness = 1, Visible = false }),
		self:_create("Line", { Thickness = 1, Visible = false }),
		self:_create("Line", { Thickness = 1, Visible = false })
	}
end

local function hideDrawings(group)
	for _, drawing in group do
		if drawing.Visible then
			drawing.Visible = false
		end
	end
end

local function needsCorners(options)
	return options.box
		or options.boxOutline
		or options.boxFill
		or options.healthBar
		or options.healthText
		or options.name
		or options.distance
		or options.weapon
		or options.tracer
		or options.box3d
end

local EspObject = {}
EspObject.__index = EspObject

function EspObject.new(player, interface)
	local self = setmetatable({}, EspObject)
	self.player = assert(player, "Missing argument #1 (Player expected)")
	self.interface = assert(interface, "Missing argument #2 (table expected)")
	self:Construct()
	return self
end

function EspObject:_create(class, properties)
	local drawing = Drawing.new(class)
	for property, value in next, properties do
		pcall(function()
			drawing[property] = value
		end)
	end
	self.bin[#self.bin + 1] = drawing
	return drawing
end

function EspObject:Construct()
	self.charCache = {}
	self.childCount = 0
	self.bin = {}
	self.drawings = {
		box3d = {
			createLineSet(self),
			createLineSet(self),
			createLineSet(self),
			createLineSet(self)
		},
		visible = {
			tracerOutline = self:_create("Line", { Thickness = 3, Visible = false }),
			tracer = self:_create("Line", { Thickness = 1, Visible = false }),
			boxFill = self:_create("Square", { Filled = true, Visible = false }),
			boxOutline = self:_create("Square", { Thickness = 3, Visible = false }),
			box = self:_create("Square", { Thickness = 1, Visible = false }),
			healthBarOutline = self:_create("Line", { Thickness = 3, Visible = false }),
			healthBar = self:_create("Line", { Thickness = 1, Visible = false }),
			healthText = self:_create("Text", { Center = true, Visible = false }),
			name = self:_create("Text", { Text = self.player.DisplayName, Center = true, Visible = false }),
			distance = self:_create("Text", { Center = true, Visible = false }),
			weapon = self:_create("Text", { Center = true, Visible = false })
		},
		hidden = {
			arrowOutline = self:_create("Triangle", { Thickness = 3, Visible = false }),
			arrow = self:_create("Triangle", { Filled = true, Visible = false })
		}
	}
end

function EspObject:Destruct()
	for i = 1, #self.bin do
		self.bin[i]:Remove()
	end
	clear(self)
end

function EspObject:Update()
	local interface = self.interface
	local player = self.player
	local options = getOptions(interface, player)
	self._teamColorCached = false
	self.options = options
	if not options.enabled then
		self.character = nil
		self.enabled = false
		self.onScreen = false
		return
	end
	local character = Utils.Player.GetCharacter(player)
	self.character = character
	self.enabled = isEnabled(interface, options, character, player.UserId)
	local head = self.enabled and findFirstChild(character, "Head")
	if not head then
		self.charCache = {}
		self.onScreen = false
		return
	end
	local _, onScreen, depth = worldToScreen(head.Position)
	self.onScreen = onScreen
	self.distance = depth
	if interface.sharedSettings.limitDistance and depth > interface.sharedSettings.maxDistance then
		self.onScreen = false
	end
	if self.onScreen then
		if options.healthBar or options.healthText then
			self.health, self.maxHealth = Utils.Player.GetHealth(player)
		end
		if options.weapon then
			self.weapon = Utils.Player.GetWeapon(player)
		end
	end
	if self.onScreen and needsCorners(options) then
		local cache = self.charCache
		local children = getChildren(character)
		if not cache[1] or self.childCount ~= #children then
			clear(cache)
			for i = 1, #children do
				local part = children[i]
				if isA(part, "BasePart") and isBodyPart(part.Name) then
					cache[#cache + 1] = part
				end
			end
			self.childCount = #children
		end
		local cframe, size = getBoundingBox(cache)
		self.corners = calculateCorners(cframe, size, self.corners)
	elseif options.offScreenArrow then
		local flat = fromMatrix(camera.CFrame.Position, camera.CFrame.RightVector, Vector3.yAxis)
		local objectSpace = flat:PointToObjectSpace(head.Position)
		self.direction = Vector2.new(objectSpace.X, objectSpace.Z).Unit
	end
end

function EspObject:Render()
	local enabled = self.enabled or false
	local onScreen = self.onScreen or false
	local options = self.options
	local corners = self.corners
	local visible = self.drawings.visible
	local hidden = self.drawings.hidden
	local box3d = self.drawings.box3d
	if not enabled then
		hideDrawings(visible)
		hideDrawings(hidden)
		for i = 1, 4 do
			hideDrawings(box3d[i])
		end
		return
	end
	if not onScreen then
		hideDrawings(visible)
		for i = 1, 4 do
			hideDrawings(box3d[i])
		end
		hidden.arrow.Visible = options.offScreenArrow
		hidden.arrowOutline.Visible = hidden.arrow.Visible and options.offScreenArrowOutline
		if hidden.arrow.Visible and self.direction then
			local arrow = hidden.arrow
			arrow.PointA = (viewportSize * 0.5 + self.direction * options.offScreenArrowRadius):Max(Vector2.one * 25):Min(viewportSize - Vector2.one * 25)
			arrow.PointB = arrow.PointA - rotateVector(self.direction, 0.45) * options.offScreenArrowSize
			arrow.PointC = arrow.PointA - rotateVector(self.direction, -0.45) * options.offScreenArrowSize
			arrow.Color = parseColor(self, options.offScreenArrowColor[1])
			arrow.Transparency = options.offScreenArrowColor[2]
			local outline = hidden.arrowOutline
			outline.PointA = arrow.PointA
			outline.PointB = arrow.PointB
			outline.PointC = arrow.PointC
			outline.Color = parseColor(self, options.offScreenArrowOutlineColor[1], true)
			outline.Transparency = options.offScreenArrowOutlineColor[2]
		end
		return
	end
	local interface = self.interface
	visible.box.Visible = enabled and onScreen and options.box
	visible.boxOutline.Visible = visible.box.Visible and options.boxOutline
	if visible.box.Visible then
		local box = visible.box
		box.Position = corners.topLeft
		box.Size = corners.bottomRight - corners.topLeft
		box.Color = parseColor(self, options.boxColor[1])
		box.Transparency = options.boxColor[2]
		local outline = visible.boxOutline
		outline.Position = box.Position
		outline.Size = box.Size
		outline.Color = parseColor(self, options.boxOutlineColor[1], true)
		outline.Transparency = options.boxOutlineColor[2]
	end
	visible.boxFill.Visible = enabled and onScreen and options.boxFill
	if visible.boxFill.Visible then
		local fill = visible.boxFill
		fill.Position = corners.topLeft
		fill.Size = corners.bottomRight - corners.topLeft
		fill.Color = parseColor(self, options.boxFillColor[1])
		fill.Transparency = options.boxFillColor[2]
	end
	visible.healthBar.Visible = enabled and onScreen and options.healthBar
	visible.healthBarOutline.Visible = visible.healthBar.Visible and options.healthBarOutline
	if visible.healthBar.Visible then
		local ratio = self.health / self.maxHealth
		local barFrom = corners.topLeft - HEALTH_BAR_OFFSET
		local barTo = corners.bottomLeft - HEALTH_BAR_OFFSET
		local bar = visible.healthBar
		bar.To = barTo
		bar.From = barTo:Lerp(barFrom, ratio)
		bar.Color = lerpColor(options.dyingColor, options.healthyColor, ratio)
		local outline = visible.healthBarOutline
		outline.To = barTo + HEALTH_BAR_OUTLINE_OFFSET
		outline.From = barFrom - HEALTH_BAR_OUTLINE_OFFSET
		outline.Color = parseColor(self, options.healthBarOutlineColor[1], true)
		outline.Transparency = options.healthBarOutlineColor[2]
	end
	visible.healthText.Visible = enabled and onScreen and options.healthText
	if visible.healthText.Visible then
		local ratio = self.health / self.maxHealth
		local barFrom = corners.topLeft - HEALTH_BAR_OFFSET
		local barTo = corners.bottomLeft - HEALTH_BAR_OFFSET
		local text = visible.healthText
		text.Text = round(self.health) .. "hp"
		applyTextStyle(text, interface.sharedSettings, parseColor(self, options.healthTextColor[1]), options.healthTextColor[2], options.healthTextOutline, parseColor(self, options.healthTextOutlineColor, true))
		text.Position = barTo:Lerp(barFrom, ratio) - text.TextBounds * 0.5 - HEALTH_TEXT_OFFSET
	end
	visible.name.Visible = enabled and onScreen and options.name
	if visible.name.Visible then
		local text = visible.name
		applyTextStyle(text, interface.sharedSettings, parseColor(self, options.nameColor[1]), options.nameColor[2], options.nameOutline, parseColor(self, options.nameOutlineColor, true))
		text.Position = (corners.topLeft + corners.topRight) * 0.5 - Vector2.yAxis * text.TextBounds.Y - NAME_OFFSET
	end
	visible.distance.Visible = enabled and onScreen and self.distance and options.distance
	if visible.distance.Visible then
		local text = visible.distance
		text.Text = round(self.distance) .. " studs"
		applyTextStyle(text, interface.sharedSettings, parseColor(self, options.distanceColor[1]), options.distanceColor[2], options.distanceOutline, parseColor(self, options.distanceOutlineColor, true))
		text.Position = (corners.bottomLeft + corners.bottomRight) * 0.5 + DISTANCE_OFFSET
	end
	visible.weapon.Visible = enabled and onScreen and options.weapon
	if visible.weapon.Visible then
		local text = visible.weapon
		text.Text = self.weapon
		applyTextStyle(text, interface.sharedSettings, parseColor(self, options.weaponColor[1]), options.weaponColor[2], options.weaponOutline, parseColor(self, options.weaponOutlineColor, true))
		text.Position = (corners.bottomLeft + corners.bottomRight) * 0.5 + (visible.distance.Visible and DISTANCE_OFFSET + Vector2.yAxis * visible.distance.TextBounds.Y or Vector2.zero)
	end
	visible.tracer.Visible = enabled and onScreen and options.tracer
	visible.tracerOutline.Visible = visible.tracer.Visible and options.tracerOutline
	if visible.tracer.Visible then
		local tracer = visible.tracer
		tracer.Color = parseColor(self, options.tracerColor[1])
		tracer.Transparency = options.tracerColor[2]
		tracer.To = (corners.bottomLeft + corners.bottomRight) * 0.5
		tracer.From = options.tracerOrigin == "Middle" and viewportSize * 0.5 or options.tracerOrigin == "Top" and viewportSize * Vector2.new(0.5, 0) or viewportSize * Vector2.new(0.5, 1)
		local outline = visible.tracerOutline
		outline.Color = parseColor(self, options.tracerOutlineColor[1], true)
		outline.Transparency = options.tracerOutlineColor[2]
		outline.To = tracer.To
		outline.From = tracer.From
	end
	hideDrawings(hidden)
	local box3dEnabled = enabled and onScreen and options.box3d
	for i = 1, 4 do
		local face = box3d[i]
		for i2 = 1, 3 do
			local line = face[i2]
			line.Visible = box3dEnabled
			line.Color = parseColor(self, options.box3dColor[1])
			line.Transparency = options.box3dColor[2]
		end
		if box3dEnabled then
			local nextIndex = i == 4 and 1 or i + 1
			local topIndex = i == 4 and 5 or i + 5
			local endIndex = i == 4 and 8 or i + 4
			face[1].From = corners.corners[i]
			face[1].To = corners.corners[nextIndex]
			face[2].From = corners.corners[nextIndex]
			face[2].To = corners.corners[topIndex]
			face[3].From = corners.corners[topIndex]
			face[3].To = corners.corners[endIndex]
		end
	end
end

local ChamObject = {}
ChamObject.__index = ChamObject

function ChamObject.new(player, interface)
	local self = setmetatable({}, ChamObject)
	self.player = assert(player, "Missing argument #1 (Player expected)")
	self.interface = assert(interface, "Missing argument #2 (table expected)")
	self:Construct()
	return self
end

function ChamObject:Construct()
	self.highlight = Instance.new("Highlight", container)
end

function ChamObject:Destruct()
	self.highlight:Destroy()
	clear(self)
end

function ChamObject:Update()
	local esp = self.interface._objectCache[self.player]
	local options, character, enabled
	if esp and esp[1] then
		local object = esp[1]
		self._teamColorCached = object._teamColorCached
		self._teamColor = object._teamColor
		options = object.options
		character = object.character
		enabled = object.enabled
	else
		local player = self.player
		local interface = self.interface
		options = getOptions(interface, player)
		character = Utils.Player.GetCharacter(player)
		enabled = isEnabled(interface, options, character, player.UserId)
		self._teamColorCached = false
	end
	local highlight = self.highlight
	if not enabled or not options.chams then
		if highlight.Enabled then
			highlight.Enabled = false
		end
		return
	end
	highlight.Enabled = true
	highlight.Adornee = character
	highlight.FillColor = parseColor(self, options.chamsFillColor[1])
	highlight.FillTransparency = options.chamsFillColor[2]
	highlight.OutlineColor = parseColor(self, options.chamsOutlineColor[1], true)
	highlight.OutlineTransparency = options.chamsOutlineColor[2]
	highlight.DepthMode = options.chamsVisibleOnly and "Occluded" or "AlwaysOnTop"
end

local InstanceObject = {}
InstanceObject.__index = InstanceObject

function InstanceObject.new(instance, options)
	local self = setmetatable({}, InstanceObject)
	self.instance = assert(instance, "Missing argument #1 (Instance Expected)")
	self.options = assert(options, "Missing argument #2 (table expected)")
	self:Construct()
	return self
end

function InstanceObject:Construct()
	local options = self.options
	options.enabled = options.enabled == nil and true or options.enabled
	options.text = options.text or "{name}"
	options.textColor = options.textColor or { Color3.new(1, 1, 1), 1 }
	options.textOutline = options.textOutline == nil and true or options.textOutline
	options.textOutlineColor = options.textOutlineColor or Color3.new()
	options.textSize = options.textSize or 13
	options.textFont = options.textFont or 2
	options.limitDistance = options.limitDistance or false
	options.maxDistance = options.maxDistance or 150
	self.text = Drawing.new("Text")
	self.text.Center = true
	self.renderConnection = runService.Heartbeat:Connect(function()
		self:Render()
	end)
end

function InstanceObject:Destruct()
	self.renderConnection:Disconnect()
	self.text:Remove()
end

function InstanceObject:Render()
	local instance = self.instance
	if not instance or not instance.Parent then
		return self:Destruct()
	end
	local text = self.text
	local options = self.options
	if not options.enabled then
		text.Visible = false
		return
	end
	local world = getPivot(instance).Position
	local position, visible, depth = worldToScreen(world)
	if options.limitDistance and depth > options.maxDistance then
		visible = false
	end
	text.Visible = visible
	if text.Visible then
		text.Position = position
		text.Color = options.textColor[1]
		text.Transparency = options.textColor[2]
		text.Outline = options.textOutline
		text.OutlineColor = options.textOutlineColor
		text.Size = options.textSize
		text.Font = options.textFont
		text.Text = options.text:gsub("{name}", instance.Name):gsub("{distance}", round(depth)):gsub("{position}", tostring(world))
	end
end

